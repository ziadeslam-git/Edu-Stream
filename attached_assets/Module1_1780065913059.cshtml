    ViewData["Title"] = "الموديول الأول — المفاهيم الأساسية في إنتاج برامج التلعيب";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="module-content" dir="rtl">

    {{!-- HERO --}}
    <div class="module-hero bg-primary text-white rounded-4 p-4 mb-4">
        <div class="d-flex align-items-center gap-3 mb-2">
            <span class="fs-1">🎮</span>
            <div>
                <h1 class="h3 mb-0">الموديول الأول</h1>
                <p class="mb-0 opacity-75">المفاهيم الأساسية في إنتاج برامج التلعيب وبعض مهارات استخدام برنامج Genially</p>
            </div>
        </div>
        <div class="badge bg-white text-primary mt-2">الهدف العام: الحصول على المعارف والحقائق العلمية المتعلقة بإنتاج برامج التلعيب</div>
    </div>

    {{!-- OBJECTIVES --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-light fw-bold">🎯 الأهداف الخاصة الإجرائية</div>
        <div class="card-body">
            <p class="text-muted">عزيزي المتدرب، بعد دراستك لهذا الموديول يرجى أن تكون قادراً على:</p>
            <div class="row g-2">
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-1">✅ تعريف التلعيب بدقة</li>
                        <li class="list-group-item border-0 py-1">✅ تعداد أنواع التلعيب</li>
                        <li class="list-group-item border-0 py-1">✅ شرح خصائص برامج التلعيب</li>
                        <li class="list-group-item border-0 py-1">✅ بيان فوائد برامج التلعيب</li>
                        <li class="list-group-item border-0 py-1">✅ إنشاء حساب لتسجيل الدخول على Genially</li>
                        <li class="list-group-item border-0 py-1">✅ تحليل مكونات لوحة الأيقونات</li>
                        <li class="list-group-item border-0 py-1">✅ التعرف على الأدوات (الشريط العلوي والجانبي)</li>
                        <li class="list-group-item border-0 py-1">✅ اختيار قالب مناسب (عرض تقديمي، لعبة، خريطة ذهنية)</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-1">✅ التحكم في الخلفيات وتنسيق الشرائح</li>
                        <li class="list-group-item border-0 py-1">✅ التعرف على أدوات الإضافة (نص، صورة، فيديو، أيقونات)</li>
                        <li class="list-group-item border-0 py-1">✅ استخدام الطبقات (Layers) لتنظيم العناصر</li>
                        <li class="list-group-item border-0 py-1">✅ تنسيق النصوص (الحجم، اللون، المحاذاة)</li>
                        <li class="list-group-item border-0 py-1">✅ إدراج الأشكال والصور من مكتبة البرنامج أو من الجهاز</li>
                        <li class="list-group-item border-0 py-1">✅ شرح الأوامر الموجودة في قائمة Transaction</li>
                        <li class="list-group-item border-0 py-1">✅ توضيح استخدامات قائمة Animations</li>
                        <li class="list-group-item border-0 py-1">✅ استخدام الطبقات ومحاذاة العناصر</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    {{!-- SECTION 1: تعريف التلعيب --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#4F46E5">📖 أولاً: تعريف التلعيب</div>
        <div class="card-body">
            <p>أدى التقدم التقني والتطور التكنولوجي إلى ظهور العديد من طرق وإستراتيجيات التعليم الجديدة التي تسهم في زيادة دافعية الطلاب نحو التعلم، وتجعل التعلم أكثر متعة وتحفيزاً وتشويقاً.</p>
            <div class="alert alert-primary border-start border-primary border-4">
                <strong>التعريف:</strong> التلعيب هو تطبيق عناصر اللعبة وتقنيات التصميم الرقمي للألعاب في تحقيق أهداف وحل مشاكل في ميادين أخرى خارج سياق الألعاب مثل الإعلام والتسويق والتعليم.
            </div>
            <p>والتلعيب في التعليم هو منحى تعليمي لتحفيز الطلاب على التعلم باستخدام عناصر الألعاب في بيئات التعلم، بهدف تحقيق أقصى قدر من المتعة والمشاركة من خلال جذب اهتمام المتعلمين لمواصلة التعلم.</p>
            <h6 class="fw-bold mt-3">يمكن تحقيق التلعيب في التعليم من خلال:</h6>
            <ul>
                <li>إضافة نقاط إلى المهام والواجبات الدراسية</li>
                <li>تحديد شارات ومنحها للمتفوقين بعد استيفاء معايير محددة</li>
                <li>إنشاء اللائحة الترتيبية للطلاب المتفوقين</li>
                <li>تحديد مستويات لتكرار المهام أو أداء مهام أصعب</li>
                <li>ربط الشارات المحصل عليها بالدخول إلى مستويات أعلى</li>
            </ul>
        </div>
    </div>

    {{!-- SECTION 2: أنواع التلعيب --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#7C3AED">🔢 ثانياً: أنواع التلعيب الرئيسية</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
                    <div class="card h-100 border-primary">
                        <div class="card-body">
                            <h6 class="fw-bold text-primary">التلعيب الهيكلي (Structural)</h6>
                            <p class="small">استخدام عناصر الألعاب دون تغيير المحتوى نفسه، بل إضافته كإطار تحفيزي.</p>
                            <p class="small text-muted"><strong>أمثلة:</strong> النقاط (Points)، الشارات (Badges)، لوحات الصدارة (Leaderboards)، المستويات (Levels)</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-success">
                        <div class="card-body">
                            <h6 class="fw-bold text-success">التلعيب المحتوي (Content)</h6>
                            <p class="small">دمج عناصر اللعبة داخل المحتوى التعليمي لتغيير طريقة تقديمه وجعله أكثر تفاعلية.</p>
                            <p class="small text-muted"><strong>أمثلة:</strong> القصص (Narrative)، الشخصيات الرمزية (Avatars)، التحديات والمغامرات</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 border-warning">
                        <div class="card-body">
                            <h6 class="fw-bold text-warning">التلعيب الاجتماعي (Social)</h6>
                            <p class="small">يركز على التفاعل والتعاون بين المشاركين لتعزيز روح الفريق والمنافسة الودية.</p>
                            <p class="small text-muted"><strong>أمثلة:</strong> العمل الجماعي، المسابقات، التعليقات الفورية من الأقران</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{!-- SECTION 3: فوائد التلعيب --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#059669">🌟 ثالثاً: فوائد استخدام برامج التلعيب في التعليم</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="d-flex gap-2 mb-3">
                        <span class="fs-4">🎯</span>
                        <div><strong>تعزيز الانخراط في التعلم</strong><br><small class="text-muted">يقدم عناصر مثل النقاط والأوسمة والمكافآت التي تلبي الرغبة المتأصلة في الإنجاز والتقدير.</small></div>
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <span class="fs-4">🧠</span>
                        <div><strong>تحسين الحفظ والفهم</strong><br><small class="text-muted">المشاركة النشطة تؤدي إلى تحسين استيعاب الطالب للموضوع وفهمه فهماً أعمق.</small></div>
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <span class="fs-4">🛤️</span>
                        <div><strong>تهيئة مسارات التعلم الشخصية</strong><br><small class="text-muted">يمكن للطلاب التقدم بالسرعة التي تناسبهم وتلقي تعليقات فورية بشأن أدائهم.</small></div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="d-flex gap-2 mb-3">
                        <span class="fs-4">🤝</span>
                        <div><strong>توطيد روح التعاون</strong><br><small class="text-muted">طبيعة الألعاب التفاعلية توطد روح التعاون والعمل الجماعي.</small></div>
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <span class="fs-4">💡</span>
                        <div><strong>تطبيق المعارف النظرية عملياً</strong><br><small class="text-muted">غالباً ما يحاكي أسلوب اللعب سيناريوهات العالم الحقيقي.</small></div>
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <span class="fs-4">😌</span>
                        <div><strong>الحد من قلق التعلم</strong><br><small class="text-muted">يقدم عنصراً من المرح والإثارة مما يخفف التوتر ويخلق ارتباطاً إيجابياً بالتعلم.</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{!-- SECTION 4: تطبيقات التلعيب --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#DC2626">📱 رابعاً: تطبيقات توظف التلعيب في التعليم</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-4">
