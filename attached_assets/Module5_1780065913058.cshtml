@* Views/Modules/Content/Module5.cshtml *@
@{
    ViewData["Title"] = "الموديول الخامس — توظيف المنصات الاجتماعية وإدارة التعلم";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="module-content" dir="rtl">

    <div class="module-hero text-white rounded-4 p-4 mb-4" style="background:#0EA5E9">
        <div class="d-flex align-items-center gap-3 mb-2">
            <span class="fs-1">🌐</span>
            <div>
                <h1 class="h3 mb-0">الموديول الخامس</h1>
                <p class="mb-0 opacity-75">توظيف المنصات الاجتماعية وإدارة التعلم</p>
            </div>
        </div>
        <div class="badge bg-white text-info mt-2">الهدف العام: توظيف المنصات الاجتماعية وإدارة التعلم لدى معلمي المرحلة الثانوية</div>
    </div>

    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header bg-light fw-bold">🎯 الأهداف الخاصة الإجرائية</div>
        <div class="card-body">
            <div class="row g-2">
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-1">✅ توظيف Telegram وMicrosoft Teams للتواصل المهني</li>
                        <li class="list-group-item border-0 py-1">✅ تنظيم مجموعات نقاش وأنشطة تعاونية</li>
                        <li class="list-group-item border-0 py-1">✅ إدارة بيئة تفاعلية عبر المنصات الرقمية</li>
                        <li class="list-group-item border-0 py-1">✅ استخدام Edmodo وGoogle Classroom</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item border-0 py-1">✅ إعداد اختبارات إلكترونية بـ Google Forms وMicrosoft Forms</li>
                        <li class="list-group-item border-0 py-1">✅ إجادة WordPress وBlogger</li>
                        <li class="list-group-item border-0 py-1">✅ تحليل البيانات بـ Google Analytics</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    {{!-- المنصات التواصلية --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#0EA5E9">💬 أولاً: منصات التواصل المهني</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card border-0 h-100" style="background:#EFF6FF">
                        <div class="card-body">
                            <h5 class="fw-bold text-primary">🏢 Microsoft Teams</h5>
                            <p class="small text-muted">للعمل المؤسسي والمنظم بين المعلمين في المدرسة أو الإدارة.</p>
                            <ul class="small mb-0">
                                <li><strong>القنوات التخصصية:</strong> قنوات حسب التخصص (معلمي الحاسب، مبدعي Genially)</li>
                                <li><strong>مشاركة الملفات (Cloud):</strong> رفع قوالب Genially القابلة للتعديل</li>
                                <li><strong>الاجتماعات الدورية:</strong> ورش عمل أونلاين لتبادل الخبرات</li>
                                <li><strong>التكامل مع التطبيقات:</strong> إدراج روابط Genially مباشرة في التبويبات</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 h-100" style="background:#F0FDF4">
                        <div class="card-body">
                            <h5 class="fw-bold text-success">✈️ Telegram — المستودع الرقمي السريع</h5>
                            <p class="small text-muted">الأفضل لتبادل المصادر الضخمة والتواصل الفوري والمرن.</p>
                            <ul class="small mb-0">
                                <li><strong>القنوات (Channels):</strong> لنشر روابط ألعاب Genially وفيديوهات CapCut</li>
                                <li><strong>لا تستهلك مساحة الهاتف</strong> وتسمح بآلاف المشتركين</li>
                                <li><strong>البوتات (Bots):</strong> لتحويل الصيغ وتنظيم المسابقات</li>
                                <li><strong>ملفات حتى 2 جيجابايت:</strong> مثالي لفيديوهات CapCut</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-3">
                <h6 class="fw-bold">📋 آداب التواصل الرقمي (Netiquette)</h6>
                <ul class="small mb-0">
                    <li>احترم أوقات الزملاء والتزم بموضوع القناة</li>
                    <li>عند مشاركة رابط لعبة Genially: اكتب وصفاً قصيراً (الهدف — الصف المستهدف)</li>
                    <li>شجع على تبادل التغذية الراجعة البناءة بين المعلمين</li>
                </ul>
            </div>
        </div>
    </div>

    {{!-- إدارة بيئات التعلم --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#7C3AED">🏗️ ثانياً: إدارة بيئات التعلم الرقمية</div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <div class="card border-0 bg-light h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-purple">1️⃣ التخطيط الهندسي للبيئة</h6>
                            <ul class="small mb-0">
                                <li><strong>سهولة الوصول:</strong> تعمل على كل الأجهزة</li>
                                <li><strong>واجهة المستخدم (UI/UX):</strong> أقسام للمصادر والواجبات والنقاش</li>
                                <li><strong>التكامل:</strong> ربط Genially داخل Microsoft Teams</li>
                            </ul>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card border-0 bg-light h-100">
                        <div class="card-body">
                            <h6 class="fw-bold">2️⃣ إدارة المحتوى الرقمي</h6>
                            <ul class="small mb-0">
                                <li><strong>التفاعلية لا التراكمية:</strong> PDF → إنفوجرافيك تفاعلي</li>
                                <li><strong>الكبسولات المعرفية:</strong> فيديوهات CapCut قصيرة وبودكاست سريع</li>
                                <li><strong>التحديث المستمر:</strong> البيئة الثابتة تُهجر</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {{!-- أنظمة إدارة التعلم --}}
    <div class="card mb-4 border-0 shadow-sm">
        <div class="card-header fw-bold text-white" style="background:#059669">📚 ثالثاً: أنظمة إدارة التعلم (LMS)</div>
        <div class="card-body">

            <h6 class="fw-bold border-bottom pb-2">🏫 Google Classroom</h6>
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <ul class="small">
                        <li>إنشاء الفصل ودعوة الطلاب بالرموز أو البريد</li>
                        <li><strong>Stream:</strong> للتواصل الاجتماعي والتربوي</li>
                        <li><strong>Classwork:</strong> تنظيم الواجبات في موضوعات (Topics)</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="small">
                        <li>جدولة المنشورات ووضع معايير التقييم (Rubrics)</li>
                        <li>إدراج روابط Genially كنشاط تفاعلي داخل المهام</li>
                        <li>تغذية راجعة خاصة لكل طالب</li>
                    </ul>
                </div>
            </div>

            <h6 class="fw-bold border-bottom pb-2">📝 الاختبارات الإلكترونية: Google Forms & Microsoft Forms</h6>
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <ul class="small">
                        <li>الفرق بين "النموذج" و"الاختبار"</li>
                        <li>تفعيل التصحيح التلقائي</li>
                        <li>إدراج الصور والفيديوهات داخل الأسئلة</li>
                    </ul>
                </div>
                <div class="col-md-6">
                    <ul class="small">
                        <li><strong>المنطق والتشعيب (Branching):</strong> مسارات ذكية حسب الإجابة</li>
                        <li>تحديد وقت الاختبار وتأمين الردود</li>
                        <li>منع الغش الرقمي</li>
                    </ul>
                </div>
            </div>

            <h6 class="fw-bold border-bottom pb-2">📊 جدول المقارنة لأدوات التقييم والإدارة</h6>
            <div class="table-responsive">
                <table class="table table-bordered table-sm">
                    <thead class="table-dark">
                        <tr><th>الأداة</th><th>الاستخدام الأساسي</th><th>الميزة التربوية</th></tr>
                    </thead>
                    <tbody>
                        <tr><td>Google Classroom</td><td>إدارة الصف والواجبات</td><td>تنظيم تدفق المعلومات وضمان وصولها للجميع</td></tr>
                        <tr><td>Microsoft Forms</td><td>الاختبارات والاستبيانات</td><td>سرعة الحصول على نتائج وتحليلها إحصائياً</td></tr>
                        <tr><td>WordPress/Blogger</td><td>بناء موقع/مدونة تعليمية</td><td>أرشفة الإنتاج الفكري وبناء علامة شخصية</td></tr>
                        <tr><td>Google Analytics</td><td>مراقبة السلوك الرقمي</td><td>فهم اهتمامات الطلاب وتطوير المحتوى</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    {{!-- المشروع النهائي --}}
    <div class="card mb-4 border-0 shadow-sm border-warning">
        <div class="card-header bg-warning text-dark fw-bold">🏆 نشاط: المنظومة المتكاملة</div>
        <div class="card-body">
            <div class="row g-3 text-center">
                <div class="col-md-3">
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <div class="fs-2">✍️</div>
                            <strong>1. Blogger</strong>
                            <p class="small text-muted">اكتب تدوينة عن موضوعك</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <div class="fs-2">✨</div>
                            <strong>2. Genially</strong>
                            <p class="small text-muted">ضمّن عرضاً تفاعلياً داخل التدوينة</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <div class="fs-2">🏫</div>
                            <strong>3. Google Classroom</strong>
                            <p class="small text-muted">ضع رابط التدوينة كواجب</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="card border-0 bg-light">
                        <div class="card-body">
                            <div class="fs-2">📊</div>
                            <strong>4. Google Forms</strong>
                            <p class="small text-muted">صمم اختباراً وحلّل النتائج</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="text-center py-4">
        <a href="/quiz/start/5" class="btn btn-lg px-5 text-white" style="background:#0EA5E9" onclick="return confirm('هل أنت مستعد لبدء اختبار هذا الموديول؟')">
            📝 ابدأ اختبار الموديول الخامس
        </a>
    </div>

</div>
